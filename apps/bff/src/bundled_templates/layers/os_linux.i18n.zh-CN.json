{
  "alias": "Linux",
  "group": "OS",
  "slots": {
    "services": "主机"
  },
  "layer-header": {
    "columns": [
      { "label": "CPU %" },
      { "label": "内存 MB" },
      { "label": "Load 1m" },
      { "label": "FS %" }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "资源",
        "metrics": [
          { "label": "CPU %", "tip": "CPU 总使用率。" },
          { "label": "内存 %", "tip": "内存已用 / 总量。" }
        ]
      }
    ]
  },
  "dashboards": {
    "service": [
      { "title": "CPU 平均使用率（%）" },
      {
        "title": "CPU 负载",
        "expressionLabels": ["1m", "5m", "15m"]
      },
      { "title": "已分配文件 FD" },
      {
        "title": "内存 RAM（MB）",
        "expressionLabels": ["used", "total", "available", "buff/cache"]
      },
      {
        "title": "内存 Swap（MB）",
        "expressionLabels": ["free", "total"]
      },
      {
        "title": "网络带宽（KB/s）",
        "expressionLabels": ["receive", "transmit"]
      },
      {
        "title": "磁盘读/写（KB/s）",
        "expressionLabels": ["read", "written"]
      },
      { "title": "文件系统使用率（%）" },
      {
        "title": "网络状态",
        "expressionLabels": ["tcp estab", "tcp time-wait", "tcp alloc", "sockets used", "udp in-use"]
      }
    ]
  }
}
