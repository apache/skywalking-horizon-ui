{
  "key": "MESH_DP",
  "alias": "Istio Data Plane",
  "group": "Istio",
  "color": "var(--sw-info)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/envoy/metrics_service_setting/",
  "aliases": {
    "services": "Sidecar services",
    "instances": "Sidecars"
  },
  "components": {
    "service": false,
    "instances": true,
    "endpoints": false,
    "topology": false,
    "traces": false,
    "logs": true,
    "ebpfProfiling": true
  },
  "log": {
    "scope": "instance"
  },
  "layer-header": {
    "orderBy": "conns",
    "columns": [
      {
        "metric": "conns",
        "label": "Connections",
        "mqe": "avg(envoy_total_connections_used)",
        "aggregation": "avg"
      },
      {
        "metric": "threads",
        "label": "Worker Threads",
        "mqe": "avg(envoy_worker_threads)",
        "aggregation": "avg"
      },
      {
        "metric": "bugFail",
        "label": "Bug Failures",
        "mqe": "avg(envoy_bug_failures)",
        "aggregation": "avg"
      }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "Sidecar health",
        "size": "auto",
        "metrics": [
          {
            "id": "conns",
            "label": "Connections",
            "tip": "Envoy connections used across sidecars.",
            "mqe": "avg(envoy_total_connections_used)",
            "aggregation": "avg"
          },
          {
            "id": "bugFail",
            "label": "Bug Failures",
            "tip": "Envoy assertion / bug counter \u2014 should be 0 in healthy clusters.",
            "mqe": "avg(envoy_bug_failures)",
            "aggregation": "avg"
          }
        ]
      }
    ]
  },
  "dashboards": {
    "instance": [
      {
        "id": "connections",
        "title": "Connections",
        "tip": "Server-side total + parent connections (envoy_total_connections_used / envoy_parent_connections_used).",
        "type": "line",
        "unit": "conns",
        "expressions": [
          "envoy_total_connections_used",
          "envoy_parent_connections_used"
        ],
        "span": 4,
        "rowSpan": 2,
        "format": "int"
      },
      {
        "id": "worker_threads",
        "title": "Worker Threads",
        "tip": "Concurrent worker threads in use vs the max observed (envoy_worker_threads / envoy_worker_threads_max).",
        "type": "line",
        "unit": "",
        "expressions": [
          "envoy_worker_threads",
          "envoy_worker_threads_max"
        ],
        "span": 4,
        "rowSpan": 2,
        "format": "int"
      },
      {
        "id": "bug_failures",
        "title": "Bug Failures",
        "tip": "Envoy internal bug-failure counter (envoy_bug_failures). Should normally be zero \u2014 non-zero indicates an Envoy assertion / debug check tripped.",
        "type": "line",
        "unit": "count",
        "expressions": [
          "envoy_bug_failures"
        ],
        "span": 4,
        "rowSpan": 2,
        "format": "int"
      },
      {
        "id": "heap_memory",
        "title": "Heap Memory",
        "tip": "Server heap size in bytes \u2014 current value + window max (envoy_heap_memory_used / envoy_heap_memory_max_used).",
        "type": "line",
        "unit": "bytes",
        "expressions": [
          "envoy_heap_memory_used",
          "envoy_heap_memory_max_used"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "memory_allocated",
        "title": "Memory Allocated",
        "tip": "Server allocated memory (envoy_memory_allocated / envoy_memory_allocated_max).",
        "type": "line",
        "unit": "bytes",
        "expressions": [
          "envoy_memory_allocated",
          "envoy_memory_allocated_max"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "memory_physical",
        "title": "Physical Memory",
        "tip": "Server physical memory footprint (envoy_memory_physical_size / envoy_memory_physical_size_max).",
        "type": "line",
        "unit": "bytes",
        "expressions": [
          "envoy_memory_physical_size",
          "envoy_memory_physical_size_max"
        ],
        "span": 4,
        "rowSpan": 2
      }
    ]
  }
}
